# === ACP Configuration ===
ACP_WALLET_PRIVATE_KEY=0x...           # Required: Base chain wallet private key
ACP_ENTITY_KEY_ID=                      # Required: ACP session entity key ID
ACP_AGENT_WALLET_ADDRESS=0x...         # Required: Agent wallet address on Base

# === Chain RPC ===
BASE_RPC_URL=https://mainnet.base.org  # Required: Primary Base chain RPC
BASE_RPC_FALLBACK=                      # Optional: Fallback RPC endpoint

# === Database ===
DATABASE_URL=postgresql://user:pass@localhost:5434/cryptointel  # Required
DB_POOL_MAX=10                          # Optional: Max pool connections (default: 10)

# === Redis ===
REDIS_HOST=localhost                    # Optional (default: localhost)
REDIS_PORT=6379                         # Optional (default: 6379)
REDIS_PASSWORD=                         # Optional
REDIS_DB=0                              # Optional (default: 0)

# === Data Sources ===
COINGECKO_API_KEY=                      # Optional: Pro tier API key
# DexScreener: no key needed (free, 300 req/min)

# === Notifications ===
TELEGRAM_BOT_TOKEN=                     # Required: Telegram bot token
TELEGRAM_CHAT_ID=                       # Required: Chat ID for notifications
DISCORD_WEBHOOK_URL=                    # Optional: Discord daily report webhook
ENABLE_DISCORD=false                    # Optional (default: false)

# === Admin API ===
ADMIN_API_PORT=14910                    # Optional (default: 14910)
ADMIN_API_KEY=                          # Required: API key for admin endpoints

# === Operational ===
NODE_ENV=development                    # development | production
LOG_LEVEL=info                          # error | warn | info | debug
MAX_DAILY_SPEND=1.00                    # Max daily USDC spend
DAILY_WITHDRAW_LIMIT=10.00             # Max daily USDC withdrawal
WITHDRAW_WHITELIST=                     # Comma-separated allowed withdrawal addresses

# === Service Prices (USDC) ===
PRICE_QUICK_SCAN=0.05
PRICE_TX_PREFLIGHT=0.01
PRICE_DEEP_DIVE=0.50

# === Risk Scoring Weights (0.0~1.0, must sum to 1.0) ===
RISK_WEIGHT_LIQUIDITY=0.30
RISK_WEIGHT_VOLATILITY=0.25
RISK_WEIGHT_HOLDER_CONCENTRATION=0.25
RISK_WEIGHT_CONTRACT_VERIFIED=0.20
