{
  "name": "@openagentx/discord-bot",
  "version": "0.1.0",
  "description": "Reusable Discord Interactions bot toolkit for OpenAgentX-style marketplaces and AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./signature": {
      "types": "./dist/signature.d.ts",
      "import": "./dist/signature.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx tests/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["discord", "discord-bot", "interactions", "slash-commands", "openagentx", "ed25519"],
  "license": "MIT",
  "author": "OpenAgentX Contributors",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
